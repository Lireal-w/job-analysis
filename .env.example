# ==========================================
# MongoDB 数据库配置
# ==========================================
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DATABASE="jobs"

# 数据存储集合名称
MONGODB_JOB_COLLECTION="jobs"
MONGODB_COMPANY_COLLECTION="companies"

# Redis 配置（Cookie 缓存）
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DATABASE=0
REDIS_COOKIE_KEY_PREFIX="cookie"
# Cookie 缓存过期时间（秒），默认 24 小时
COOKIE_EXPIRE_SECONDS=86400

# ==========================================
# 搜索配置
# ==========================================
# 搜索关键词（逗号分隔）
SEARCH_KEYWORDS="Python,Java,前端,数据分析,产品经理,运营"
# 目标地区（逗号分隔，支持城市名、省份名、地区ID）
# 示例：北京,上海,530,广东
SEARCH_REGIONS="北京,上海,广州,深圳,杭州,成都,武汉,南京"
# 最大翻页数
SEARCH_MAX_PAGE=10
